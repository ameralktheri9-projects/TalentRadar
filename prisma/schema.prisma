generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IndustrySector {
  TECHNOLOGY
  HEALTHCARE
  FINANCE
  EDUCATION
  RETAIL
  MANUFACTURING
  CONSTRUCTION
  ENERGY
  LOGISTICS
  HOSPITALITY
  MEDIA
  GOVERNMENT
  OTHER
}

enum SaudiCity {
  RIYADH
  JEDDAH
  MECCA
  MEDINA
  DAMMAM
  KHOBAR
  DHAHRAN
  TABUK
  ABHA
  TAIF
  NAJRAN
  JIZAN
  HAIL
  OTHER
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum CompanyUserRole {
  HR_MANAGER
  TA_LEAD
  BU_MANAGER
}

enum UserStatus {
  ACTIVE
  INVITED
  DEACTIVATED
}

enum ClientType {
  ENTERPRISE
  SME
  STARTUP
}

enum SubscriptionTier {
  FREE
  BASIC
  PRO
  ELITE
}

enum AgencyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum AgencyUserRole {
  OWNER
  RECRUITER
  FINANCE
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
  DIRECTOR
  C_SUITE
}

enum BudgetType {
  PERCENTAGE_OF_SALARY
  FLAT_FEE
}

enum JobRequestStatus {
  DRAFT
  OPEN
  CLOSED
  FILLED
  CANCELLED
}

enum FeeType {
  PERCENTAGE
  FLAT
}

enum ProposalStatus {
  SUBMITTED
  SHORTLISTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum CandidateStatus {
  SUBMITTED
  VIEWED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  OFFER_MADE
  HIRED
  REJECTED
}

enum InterviewType {
  PHONE
  VIDEO
  ONSITE
}

enum InterviewOutcome {
  PENDING
  PASSED
  FAILED
  NO_SHOW
  CANCELLED
}

enum PlacementStatus {
  OFFER_MADE
  ACCEPTED
  DECLINED
  STARTED
  GUARANTEE_BREACH
  REPLACED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  DISPUTED
  REFUNDED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model Company {
  id                   String          @id @default(uuid())
  name_ar              String
  name_en              String
  cr_number            String          @unique
  cr_verified          Boolean         @default(false)
  industry_sector      IndustrySector
  city                 SaudiCity
  saudi_employee_count Int             @default(0)
  total_employee_count Int             @default(0)
  status               CompanyStatus   @default(PENDING)
  created_at           DateTime        @default(now())

  users                CompanyUser[]
  job_requests         JobRequest[]
  placements           Placement[]
  invoices             Invoice[]
}

model CompanyUser {
  id            String          @id @default(uuid())
  company_id    String
  full_name     String
  email         String          @unique
  password_hash String
  role          CompanyUserRole
  is_primary    Boolean         @default(false)
  status        UserStatus      @default(INVITED)

  company       Company         @relation(fields: [company_id], references: [id])
  job_requests  JobRequest[]
  interviews    Interview[]
  ratings       Rating[]
}

model Agency {
  id                    String           @id @default(uuid())
  name_ar               String
  name_en               String
  hrsd_licence          String           @unique
  hrsd_verified         Boolean          @default(false)
  founded_year          Int?
  team_size             Int              @default(1)
  sector_tags           String[]
  client_types          ClientType[]
  subscription_tier     SubscriptionTier @default(FREE)
  rating_avg            Float            @default(0)
  total_placements      Int              @default(0)
  avg_time_to_fill_days Float            @default(0)
  fill_rate             Float            @default(0)
  response_rate         Float            @default(0)
  status                AgencyStatus     @default(PENDING)
  created_at            DateTime         @default(now())

  users                 AgencyUser[]
  proposals             Proposal[]
  candidate_submissions CandidateSubmission[]
  placements            Placement[]
  invoices              Invoice[]
  ratings               Rating[]
  subscriptions         Subscription[]
  agencySubscriptions   AgencySubscription[]
}

model AgencyUser {
  id            String         @id @default(uuid())
  agency_id     String
  full_name     String
  email         String         @unique
  password_hash String
  role          AgencyUserRole
  status        UserStatus     @default(INVITED)

  agency        Agency         @relation(fields: [agency_id], references: [id])
  proposals     Proposal[]
}

model JobRequest {
  id                    String           @id @default(uuid())
  company_id            String
  created_by            String
  title                 String
  description           String
  sector                String
  experience_level      ExperienceLevel
  salary_min            Int
  salary_max            Int
  saudi_national_required Boolean        @default(false)
  headcount             Int              @default(1)
  sla_days              Int              @default(30)
  budget_type           BudgetType
  budget_value          Float
  status                JobRequestStatus @default(DRAFT)
  proposal_deadline     DateTime?
  opened_at             DateTime?
  closed_at             DateTime?
  created_at            DateTime         @default(now())

  company               Company          @relation(fields: [company_id], references: [id])
  creator               CompanyUser      @relation(fields: [created_by], references: [id])
  proposals             Proposal[]
}

model Proposal {
  id                       String          @id @default(uuid())
  job_request_id           String
  agency_id                String
  submitted_by             String
  candidate_count_available Int            @default(0)
  fee_type                 FeeType
  fee_value                Float
  timeline_days            Int
  guarantee_days           Int             @default(90)
  notes                    String?
  status                   ProposalStatus  @default(SUBMITTED)
  submitted_at             DateTime        @default(now())
  responded_at             DateTime?

  job_request              JobRequest      @relation(fields: [job_request_id], references: [id])
  agency                   Agency          @relation(fields: [agency_id], references: [id])
  submitter                AgencyUser      @relation(fields: [submitted_by], references: [id])
  candidate_submissions    CandidateSubmission[]
  messageThread            MessageThread?
}

model CandidateSubmission {
  id               String          @id @default(uuid())
  proposal_id      String
  agency_id        String
  anon_summary     String?
  full_name        String
  email            String
  phone            String?
  cv_url           String?
  current_title    String?
  years_experience Int             @default(0)
  nationality      String?
  is_saudi         Boolean         @default(false)
  current_salary   Int?
  expected_salary  Int?
  status           CandidateStatus @default(SUBMITTED)
  consent_given    Boolean         @default(false)
  consent_at       DateTime?
  created_at       DateTime        @default(now())

  proposal         Proposal        @relation(fields: [proposal_id], references: [id])
  agency           Agency          @relation(fields: [agency_id], references: [id])
  interviews       Interview[]
  placement        Placement?
  linkedCandidateId String?
  linkedCandidate   Candidate?     @relation(fields: [linkedCandidateId], references: [id])
}

model Interview {
  id                      String           @id @default(uuid())
  candidate_submission_id String
  scheduled_by            String
  interview_type          InterviewType
  scheduled_at            DateTime
  calendar_event_id       String?
  outcome                 InterviewOutcome @default(PENDING)
  feedback                String?
  feedback_submitted_at   DateTime?
  created_at              DateTime         @default(now())

  candidate_submission    CandidateSubmission @relation(fields: [candidate_submission_id], references: [id])
  scheduler               CompanyUser         @relation(fields: [scheduled_by], references: [id])
}

model Placement {
  id                      String          @id @default(uuid())
  candidate_submission_id String          @unique
  company_id              String
  agency_id               String
  offer_amount            Int
  offer_made_at           DateTime        @default(now())
  offer_accepted_at       DateTime?
  start_date              DateTime?
  guarantee_end_date      DateTime?
  status                  PlacementStatus @default(OFFER_MADE)

  candidate_submission    CandidateSubmission @relation(fields: [candidate_submission_id], references: [id])
  company                 Company             @relation(fields: [company_id], references: [id])
  agency                  Agency              @relation(fields: [agency_id], references: [id])
  invoice                 Invoice?
  rating                  Rating?
  escrowTransactions      EscrowTransaction[]
}

model Invoice {
  id            String        @id @default(uuid())
  placement_id  String        @unique
  company_id    String
  agency_id     String
  gross_amount  Float
  platform_cut  Float
  agency_payout Float
  vat_amount    Float
  total_amount  Float
  status        InvoiceStatus @default(DRAFT)
  due_date      DateTime?
  paid_at       DateTime?
  payment_ref   String?
  created_at    DateTime      @default(now())

  placement     Placement     @relation(fields: [placement_id], references: [id])
  company       Company       @relation(fields: [company_id], references: [id])
  agency        Agency        @relation(fields: [agency_id], references: [id])
}

model Rating {
  id                   String      @id @default(uuid())
  placement_id         String      @unique
  rated_by             String
  agency_id            String
  score_speed          Int
  score_quality        Int
  score_professionalism Int
  score_outcome        Int
  overall_score        Float
  comment              String?
  created_at           DateTime    @default(now())

  placement            Placement   @relation(fields: [placement_id], references: [id])
  rater                CompanyUser @relation(fields: [rated_by], references: [id])
  agency               Agency      @relation(fields: [agency_id], references: [id])
}

model Subscription {
  id            String             @id @default(uuid())
  agency_id     String
  tier          SubscriptionTier
  billing_cycle BillingCycle
  price_sar     Float
  started_at    DateTime           @default(now())
  renews_at     DateTime?
  status        SubscriptionStatus @default(ACTIVE)

  agency        Agency             @relation(fields: [agency_id], references: [id])
}

model AdminUser {
  id            String   @id @default(uuid())
  full_name     String
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
}

model CandidateUser {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  phone           String?
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  profile         CandidateProfile?
}

model OtpToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userType  String
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userType  String
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model OrgInvite {
  id         String    @id @default(cuid())
  token      String    @unique
  orgType    String
  orgId      String
  email      String
  role       String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
}

model AgencySubscription {
  id                 String              @id @default(cuid())
  agencyId           String
  agency             Agency              @relation(fields: [agencyId], references: [id])
  tier               AgencyTier
  status             SubStatus           @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  hyperpayToken      String?
  cancelledAt        DateTime?
  createdAt          DateTime            @default(now())
  events             SubscriptionEvent[]
}

model CompanySubscription {
  id                 String      @id @default(cuid())
  companyId          String      @unique
  tier               CompanyTier
  status             SubStatus   @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  hyperpayToken      String?
  cancelledAt        DateTime?
  createdAt          DateTime    @default(now())
}

model SubscriptionEvent {
  id          String              @id @default(cuid())
  agencySubId String?
  agencySub   AgencySubscription? @relation(fields: [agencySubId], references: [id])
  eventType   String
  fromTier    String?
  toTier      String?
  triggeredBy String?
  occurredAt  DateTime            @default(now())
}

model Notification {
  id            String    @id @default(cuid())
  userId        String
  userType      String
  event         String
  title         String
  body          String
  referenceId   String?
  referenceType String?
  channel       String
  readAt        DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime  @default(now())
}

model MessageThread {
  id             String    @id @default(cuid())
  proposalId     String    @unique
  proposal       Proposal  @relation(fields: [proposalId], references: [id])
  companyId      String
  agencyId       String
  lastActivityAt DateTime  @default(now())
  messages       Message[]
  createdAt      DateTime  @default(now())
}

model Message {
  id              String        @id @default(cuid())
  threadId        String
  thread          MessageThread @relation(fields: [threadId], references: [id])
  senderType      String
  senderId        String
  body            String
  attachments     Json?
  isInternalNote  Boolean       @default(false)
  readByCompanyAt DateTime?
  readByAgencyAt  DateTime?
  createdAt       DateTime      @default(now())
}

model MatchScore {
  id           String   @id @default(cuid())
  jobRequestId String
  agencyId     String
  score        Int
  breakdown    Json
  computedAt   DateTime @default(now())

  @@unique([jobRequestId, agencyId])
}

model EscrowTransaction {
  id              String    @id @default(cuid())
  placementId     String
  placement       Placement @relation(fields: [placementId], references: [id])
  amount          Float
  currency        String    @default("SAR")
  heldAt          DateTime?
  releasedAt      DateTime?
  releaseReason   String?
  payoutStatus    String    @default("PENDING")
  payoutReference String?
  createdAt       DateTime  @default(now())
}

model Candidate {
  id                 String                @id @default(cuid())
  agencyId           String
  fullName           String
  titleCurrent       String?
  cvUrl              String?
  skills             String[]
  yearsExperience    Int?
  expectedSalary     Float?
  nationality        String?
  availabilityStatus String                @default("ACTIVE")
  consentGiven       Boolean               @default(false)
  createdAt          DateTime              @default(now())
  submissions        CandidateSubmission[]
}

model CandidateProfile {
  id                 String              @id @default(cuid())
  userId             String              @unique
  user               CandidateUser       @relation(fields: [userId], references: [id])
  headline           String?
  aboutMe            String?
  photoUrl           String?
  cvUrl              String?
  skills             String[]
  languages          String[]
  expectedSalaryMin  Float?
  expectedSalaryMax  Float?
  availabilityStatus String              @default("OPEN")
  visibilityMode     String              @default("PUBLIC")
  profileScore       Int                 @default(0)
  location           String?
  consentGiven       Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  experiences        WorkExperience[]
  education          Education[]
  applications       DirectApplication[]
}

model WorkExperience {
  id          String           @id @default(cuid())
  profileId   String
  profile     CandidateProfile @relation(fields: [profileId], references: [id])
  company     String
  title       String
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean          @default(false)
  description String?
  location    String?
}

model Education {
  id           String           @id @default(cuid())
  profileId    String
  profile      CandidateProfile @relation(fields: [profileId], references: [id])
  institution  String
  degree       String?
  fieldOfStudy String?
  startYear    Int
  endYear      Int?
}

model DirectApplication {
  id              String           @id @default(cuid())
  profileId       String
  profile         CandidateProfile @relation(fields: [profileId], references: [id])
  jobRequestId    String
  coverNote       String?          @db.VarChar(500)
  status          AppStatus        @default(SUBMITTED)
  aiSummary       String?
  matchScore      Int?
  appliedAt       DateTime         @default(now())
  statusUpdatedAt DateTime         @default(now())

  @@unique([profileId, jobRequestId])
}

model RatingDetail {
  id                 String @id @default(cuid())
  ratingId           String @unique
  speed              Int
  candidateQuality   Int
  communication      Int
  valueForMoney      Int
  overall            Int
}

enum AgencyTier {
  FREE
  BASIC
  PRO
  ELITE
}

enum CompanyTier {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum AppStatus {
  SUBMITTED
  UNDER_REVIEW
  INTERVIEW_INVITED
  REJECTED
  OFFER_MADE
}
